{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coalfire Ember",
  "version": "0.1.0",
  "identifier": "com.coalfire.ember-pi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Coalfire Ember",
        "width": 780,
        "height": 58,
        "minWidth": 520,
        "minHeight": 58,
        "maxWidth": 1440,
        "decorations": false,
        "transparent": false,
        "shadow": false,
        "visible": false,
        "resizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "resources": [
      "../../docker"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
